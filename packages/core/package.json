{
  "name": "@mingai/core",
  "version": "2.1.0",
  "description": "MingAI Core - 命理计算工具核心库（SDK）",
  "license": "MIT",
  "homepage": "https://github.com/hhszzzz/MingAI",
  "bugs": {
    "url": "https://github.com/hhszzzz/MingAI/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hhszzzz/MingAI.git"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
