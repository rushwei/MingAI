    },
    "./bazi-core": {
      "types": "./dist/bazi-core.d.ts",
      "default": "./dist/bazi-core.js"
    },
    "./bazi-pillars-resolve-core": {
      "types": "./dist/bazi-pillars-resolve-core.d.ts",
      "default": "./dist/bazi-pillars-resolve-core.js"
    },
    "./dayun-core": {
      "types": "./dist/dayun-core.d.ts",
      "default": "./dist/dayun-core.js"
    },
    "./fortune-core": {
      "types": "./dist/fortune-core.d.ts",
      "default": "./dist/fortune-core.js"
    },
    "./liuyao-core": {
      "types": "./dist/liuyao-core.d.ts",
      "default": "./dist/liuyao-core.js"
    },
    "./meihua-core": {
      "types": "./dist/meihua-core.d.ts",
      "default": "./dist/meihua-core.js"
    },
    "./qimen-core": {
      "types": "./dist/qimen-core.d.ts",
      "default": "./dist/qimen-core.js"
    },
    "./tarot-core": {
      "types": "./dist/tarot-core.d.ts",
      "default": "./dist/tarot-core.js"
