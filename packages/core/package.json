{
  "name": "@mingai/core",
  "version": "1.5.0",
  "description": "MingAI Core - 命理计算工具核心库（SDK）",
  "license": "MIT",
  "homepage": "https://github.com/hhszzzz/MingAI",
  "bugs": {
    "url": "https://github.com/hhszzzz/MingAI/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hhszzzz/MingAI.git"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./liuyao-core": {
      "types": "./dist/liuyao-core.d.ts",
      "default": "./dist/liuyao-core.js"
    },
    "./data/hexagram-data": {
      "types": "./dist/data/hexagram-data.d.ts",
      "default": "./dist/data/hexagram-data.js"
    },
    "./data/shensha-data": {
      "types": "./dist/data/shensha-data.d.ts",
      "default": "./dist/data/shensha-data.js"
    },
    "./utils": {
      "types": "./dist/utils.d.ts",
      "default": "./dist/utils.js"
    },
    "./dayun": {
      "types": "./dist/handlers/liunian.d.ts",
      "default": "./dist/handlers/liunian.js"
    },
    "./bazi": {
      "types": "./dist/handlers/bazi.d.ts",
      "default": "./dist/handlers/bazi.js"
    },
    "./ziwei": {
      "types": "./dist/handlers/ziwei.d.ts",
      "default": "./dist/handlers/ziwei.js"
    },
    "./qimen": {
      "types": "./dist/handlers/qimen.d.ts",
      "default": "./dist/handlers/qimen.js"
    },
    "./daliuren": {
      "types": "./dist/daliuren/index.d.ts",
      "default": "./dist/daliuren/index.js"
    },
    "./tarot": {
      "types": "./dist/tarot.d.ts",
      "default": "./dist/tarot.js"
    },
    "./transport": {
      "types": "./dist/transport.d.ts",
      "default": "./dist/transport.js"
    },
    "./text": {
      "types": "./dist/text.d.ts",
      "default": "./dist/text.js"
    },
    "./timezone-utils": {
      "types": "./dist/timezone-utils.d.ts",
      "default": "./dist/timezone-utils.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "mcp",
    "mingai",
    "bazi",
    "ziwei",
    "liuyao",
    "qimen",
    "tarot",
    "daliuren",
    "divination"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "iztro": "^2.5.4",
    "liuren-ts-lib": "^1.9.0",
    "lunar-javascript": "^1.7.7",
    "taobi": "^0.4.5",
    "tyme4ts": "^1.4.4"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  }
}
