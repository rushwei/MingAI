      "default": "./dist/transport.js"
    },
    "./text": {
      "types": "./dist/text.d.ts",
      "default": "./dist/text.js"
    },
    "./json": {
      "types": "./dist/json.d.ts",
      "default": "./dist/json.js"
    },
    "./timezone-utils": {
      "types": "./dist/timezone-utils.d.ts",
      "default": "./dist/timezone-utils.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "mcp",
    "mingai",
    "bazi",
    "ziwei",
    "liuyao",
    "meihua",
    "qimen",
    "tarot",
    "daliuren",
