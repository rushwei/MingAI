    "./ziwei-core": {
      "types": "./dist/ziwei-core.d.ts",
      "default": "./dist/ziwei-core.js"
    },
    "./ziwei-horoscope-core": {
      "types": "./dist/ziwei-horoscope-core.d.ts",
      "default": "./dist/ziwei-horoscope-core.js"
    },
    "./ziwei-flying-star-core": {
      "types": "./dist/ziwei-flying-star-core.d.ts",
      "default": "./dist/ziwei-flying-star-core.js"
    },
    "./daliuren-core": {
      "types": "./dist/daliuren-core.d.ts",
      "default": "./dist/daliuren-core.js"
    },
    "./data/hexagram-data": {
      "types": "./dist/data/hexagram-data.d.ts",
      "default": "./dist/data/hexagram-data.js"
