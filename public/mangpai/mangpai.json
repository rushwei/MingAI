[
    {
        "index": 1,
        "type": "甲子日",
        "称号": "天德贵人",
        "口诀": "甲子开元侬先来，水生木旺有文才。怕午畏卯喜寅亥，进神裸露两半开。"
    },
    {
        "index": 2,
        "type": "甲寅日",
        "称号": "天禄贵人",
        "口诀": "自坐禄位已旺哉，印刃墓聚必来灾。干支同损夫妻子，过旺要盼强金来。"
    },
    {
        "index": 3,
        "type": "甲辰日",
        "称号": "龙守财库",
        "口诀": "身坐财库要盼冲，勿忘甲在衰宫中。七杀入墓鬼点火，几多配偶常分床。"
    },
    {
        "index": 4,
        "type": "甲午日",
        "称号": "龙马奔驰",
        "口诀": "阴阳相泄死气临，秋降夏生是平民。红艳映出风流事，旺印汇禄救苍生。"
    },
    {
        "index": 5,
        "type": "甲申日",
        "称号": "龙虎夺魁",
        "口诀": "不应截脚叹绝死，斧死木把由谁使。若来亥子妙配合，才艺出众是大师。"
    },
    {
        "index": 6,
        "type": "甲戌日",
        "称号": "青龙献艺",
        "口诀": "妻宫伤官生财旺，无奈木犬喻青龙。母扶弟帮多荣耀，可叹鸳鸯各西东。"
    },
    {
        "index": 7,
        "type": "乙卯日",
        "称号": "凤云相会",
        "口诀": "侬居爵禄干支同，不透白金有何用。春冬无杀隐祸患，食神制杀包贵荣。"
    },
    {
        "index": 8,
        "type": "乙丑日",
        "称号": "玉女佩珠",
        "口诀": "身坐金库饿得慌，北丘东柳盼雨降。春生透庚荣华客，水火相济路路通。"
    },
    {
        "index": 9,
        "type": "乙酉日",
        "称号": "龙凤呈祥",
        "口诀": "阴阳冲克俱不同，若遇凤猴有伤痛。东北众神是亲家，西南得令泪汪汪。"
    },
    {
        "index": 10,
        "type": "乙未日",
        "称号": "财福进门",
        "口诀": "自坐木库内藏财，女命属羊有婚灾。春冬月提时见午，丙庚二透天下贵。"
    },
    {
        "index": 11,
        "type": "乙巳日",
        "称号": "木火生辉",
        "口诀": "木火生辉孤鸾方，叱咤风云后院霜。刚愎自用甚聪颖，败兴富贫忙碌中。"
    },
    {
        "index": 12,
        "type": "乙亥日",
        "称号": "名利双成",
        "口诀": "虽临死宫文昌贵，才艺出众扬四海。谨防水旺把木漂，命旺见火发大财。"
    },
    {
        "index": 13,
        "type": "丙子日",
        "称号": "漓江照彩",
        "口诀": "日照江河仪表丰，阳差飞刃六秀共。午巳同来命坎坷，金木相助财官荣。"
    },
    {
        "index": 14,
        "type": "丙寅日",
        "称号": "旭日东升",
        "口诀": "长生宫里印学堂，夏见庚辛财运丰。冬遇壬癸南当官，申助阳水防命丧。"
    },
    {
        "index": 15,
        "type": "丙辰日",
        "称号": "日照龙潭",
        "口诀": "日照龙潭灵德来，春母扶子显荣贵。夏生喜水冬畏子，平生命旺福如海。"
    },
    {
        "index": 16,
        "type": "丙午日",
        "称号": "天河落彩",
        "口诀": "赤马连刃干支同，伤夫克妻灾沉重。炎上命促威风足，中和才能安乐康。"
    },
    {
        "index": 17,
        "type": "丙申日",
        "称号": "火照金城",
        "口诀": "金须火炼方成才，身旺财官包显贵。丙临申忌阳水旺，戊土出干能免灾。"
    },
    {
        "index": 18,
        "type": "丙戌日",
        "称号": "天厨贵人",
        "口诀": "夏月申时庚出干，月上透水美财官。岁运警惕壬辰来，天命刑冲祸立着。"
    },
    {
        "index": 19,
        "type": "丁卯日",
        "称号": "月照蟾宫",
        "口诀": "日坐偏印虽自强，西方劲吹身即凉。春月见蛇财官美，土重晦火大不祥。"
    },
    {
        "index": 20,
        "type": "丁丑日",
        "称号": "玉女守库",
        "口诀": "身旺白虎啣金来，命弱玄武添祸灾。见木生火有文彩，朱雀乘风发大财。"
    },
    {
        "index": 21,
        "type": "丁亥日",
        "称号": "月照天门",
        "口诀": "天乙坐镇暗合成，日贵最佳夜时辰。寅卯若来旺丁火，何惧七杀来息灯。"
    },
    {
        "index": 22,
        "type": "丁酉日",
        "称号": "玉女乘凤",
        "口诀": "最喜庚金劈甲光，火炼金凤耀人间。东途才是发福地，南域荣昌富贵天。"
    },
    {
        "index": 23,
        "type": "丁未日",
        "称号": "人立画桥",
        "口诀": "夫妻两硬必刑克，冲害大烈有残缺。阴性羊刃好帮手，畏水喜木透金吉。"
    },
    {
        "index": 24,
        "type": "丁巳日",
        "称号": "朱雀跃辉",
        "口诀": "干支相同坐帝旺，阴火伴蛇婚灾重。春月透水考大官，辛金露出是富翁。"
    },
    {
        "index": 25,
        "type": "戊辰日",
        "称号": "苍龙出海",
        "口诀": "日德勾陈冠带看，太极醉扶曲直官。库藏财元宜透露，诚信忌刑稼穑欢。"
    },
    {
        "index": 26,
        "type": "戊午日",
        "称号": "马奔午门",
        "口诀": "羊刃日灵带孤鸾，黄马侣伴分北南。登明得令能大富，会刃冲合命难安。"
    },
    {
        "index": 27,
        "type": "戊申日",
        "称号": "露落花簇",
        "口诀": "文昌福星在病宫，干透明火方为荣。土猴谨防偶分离，身命露水财定丰。"
    },
    {
        "index": 28,
        "type": "戊戌日",
        "称号": "溪绕画亭",
        "口诀": "入墓自旺何用猜，出甲见庚定发财。定论魁罡分季节，局有刑冲隐藏灾。"
    },
    {
        "index": 29,
        "type": "戊子日",
        "称号": "山环水抱",
        "口诀": "人间没有穷戊子，贤妻美貌有慧智。巳禄露甲庚出干，史载名人丰财资。"
    },
    {
        "index": 30,
        "type": "戊寅日",
        "称号": "虎啸山谷",
        "口诀": "阴阳差错临长生，木火透干是能人。露杀食制不见枭，一生荣幸妻年轻。"
    },
    {
        "index": 31,
        "type": "己丑日",
        "称号": "牛拜金殿",
        "口诀": "土坐金库黄气重，若遇长生文才丰。水木会禄透佳命，山羊无情理应防。"
    },
    {
        "index": 32,
        "type": "己卯日",
        "称号": "武跨将台",
        "口诀": "坐杀临病自身衰，巳午帮助决无差。只畏金鸡来捣乱，喜盼羊儿进命宅。"
    },
    {
        "index": 33,
        "type": "己巳日",
        "称号": "马跃平川",
        "口诀": "支生干来自身强，局中有印见木昌。须防猛虎来伤命，能得蛟龙富贵长。"
    },
    {
        "index": 34,
        "type": "己未日",
        "称号": "丹桂漂香",
        "口诀": "身命自强带阴刃，透甲露癸是贵人。夜生要比昼生好，不见劫财百事顺。"
    },
    {
        "index": 35,
        "type": "己酉日",
        "称号": "凤飞绿洲",
        "口诀": "长生文昌见学堂，书画琴棋才出众。干上火烧遇合贵，避开兔儿办事通。"
    },
    {
        "index": 36,
        "type": "己亥日",
        "称号": "平川流水",
        "口诀": "切忌鬼旺事难成，印透能变好命运。身旺胜财见水发，身衰杀旺稳中慎。"
    },
    {
        "index": 37,
        "type": "庚子日",
        "称号": "金玉出海",
        "口诀": "冬月无火伤官重，春降戊己忌克冲。夏季得根文武全，秋生喜南四季丰。"
    },
    {
        "index": 38,
        "type": "庚寅日",
        "称号": "白虎镇山",
        "口诀": "日灵暗禄谁人知，赤日炎炎梦中痴。印旺见比必荣幸，若见龙狗变财主。"
    },
    {
        "index": 39,
        "type": "庚辰日",
        "称号": "德福贵人",
        "口诀": "若是魁罡定刚强，运旺为臣刑冲殃。财官两旺必遭祸，全局平衡细思量。"
    },
    {
        "index": 40,
        "type": "庚申日",
        "称号": "双虎奔驰",
        "口诀": "人间没有苦庚申，秋生透凶盼炎临。亥子来泄保平安，寅卯见一财源顺。"
    },
    {
        "index": 41,
        "type": "庚戌日",
        "称号": "禄马贵人",
        "口诀": "忌龙相冲喜卯合，冬春透火财官得。巳午相伴防寿促，寅中出甲建仁德。"
    },
    {
        "index": 42,
        "type": "庚午日",
        "称号": "火铸金印",
        "口诀": "白虎持势官和印，秋生欢喜见丙丁。水木相生助火炼，朱雀乘风土变金。"
    },
    {
        "index": 43,
        "type": "辛丑日",
        "称号": "白玉生辉",
        "口诀": "见子合生来荣华，干透辰土锦添花。命旺若见木火辉，一生富贵美如画。"
    },
    {
        "index": 44,
        "type": "辛卯日",
        "称号": "凤阙早步",
        "口诀": "阴差阳错婚不牢，暗冲禄马毕欠好。若见旺印来救助，支中有根实在妙。"
    },
    {
        "index": 45,
        "type": "辛巳日",
        "称号": "金马登殿",
        "口诀": "一颗珠宝被蛇吞，辛若无根死气沉。最喜高山一青松，夕阳映红财官盛。"
    },
    {
        "index": 46,
        "type": "辛未日",
        "称号": "冰河解冻",
        "口诀": "支虽生干在衰宫，申酉月生必兴旺。午门之下扬武权，不喜牛狗来刑冲。"
    },
    {
        "index": 47,
        "type": "辛酉日",
        "称号": "凤卧金山",
        "口诀": "禄临阴差干支同，男女逢之均过旺。泄到恰时方为贵，木火相生财官荣。"
    },
    {
        "index": 48,
        "type": "辛亥日",
        "称号": "虎行天门",
        "口诀": "身轻怎能胜财官，见帮有助才能欢。戊子时见朝阳格，运走西方富贵看。"
    },
    {
        "index": 49,
        "type": "壬子日",
        "称号": "马奔天河",
        "口诀": "黑鼠带刃干支同，男女婚姻坎坷中。东南来神福乐贵，西北波浪冲富来。"
    },
    {
        "index": 50,
        "type": "壬寅日",
        "称号": "福禄合贵",
        "口诀": "阳木泄水在病状，文昌孤鸾旺妻宫。戎亥透土若见午，见金风流富贵中。"
    },
    {
        "index": 51,
        "type": "壬辰日",
        "称号": "山水长流",
        "口诀": "名称繁多论何方，虚名虚利任君用。自坐墓库三分凶，命旺财官必显荣。"
    },
    {
        "index": 52,
        "type": "壬午日",
        "称号": "花红柳绿",
        "口诀": "财官双美水火济，癸克子冲均不希。金生亥扶财官旺，木火太重必受欺。"
    },
    {
        "index": 53,
        "type": "壬申日",
        "称号": "白虎渡江",
        "口诀": "学堂太极长生位，水涝土卑人市侩。一木独透支有根，促寿丙临遍地财。"
    },
    {
        "index": 54,
        "type": "壬戌日",
        "称号": "龙出苍海",
        "口诀": "日德坐财命见旺，水临火库有印帮。干透庚丙支会辰，发富全靠此一冲。"
    },
    {
        "index": 55,
        "type": "癸丑日",
        "称号": "桑柳成荫",
        "口诀": "玄武羊刃不论凶，自强勤俭衣食丰。土旺防疾亥隐晦，功名落在申酉中。"
    },
    {
        "index": 56,
        "type": "癸卯日",
        "称号": "天姿文秀",
        "口诀": "天乙文昌在长生，食神无枭事途顺。金为刀笔书香浓，辰丑富贵子酉损。"
    },
    {
        "index": 57,
        "type": "癸巳日",
        "称号": "彩霞佩玉",
        "口诀": "水来土挡出英才，巳午亥子冲中魁。贵人玉堂财官美，四季太盛有婚灾。"
    },
    {
        "index": 58,
        "type": "癸未日",
        "称号": "贵人展姿",
        "口诀": "偏官十灵智慧聪，水入木库添美容。乐逢金水见微火，忌见丑内暗鬼冲。"
    },
    {
        "index": 59,
        "type": "癸酉日",
        "称号": "天福金像",
        "口诀": "支生天干坐偏印，逢财生官是荣幸。杀透有制必富贵，太阳一出万事欣。"
    },
    {
        "index": 60,
        "type": "癸亥日",
        "称号": "天门悬彩",
        "口诀": "再见水汇必隐晦，事业婚姻要防灾。东南才是发富地，水火相济放光采。"
    }
]